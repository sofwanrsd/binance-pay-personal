# ============================================================
# Binance Pay Gateway - AKUN PERSONAL
# Salin file ini ke .env lalu isi nilai yang sesuai
# ============================================================

# --- API Credentials ---
# Buat di: Binance -> Settings -> API Management
# Permission yang dibutuhkan: Enable Reading SAJA
# JANGAN aktifkan Spot Trading / Withdraw / Futures
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# --- Binance Pay ID ---
# Pay ID kamu yang ditampilkan ke buyer untuk transfer
# Cek di: Binance app -> Pay -> Pay ID (pojok kanan atas)
BINANCE_PAY_ID=123456789

# --- Konfigurasi Invoice ---
# Mata uang yang diterima (dipisah koma). Contoh: USDT,BNB
ACCEPTED_CURRENCIES=USDT

# Berapa menit invoice berlaku sebelum EXPIRED (default: 30)
INVOICE_EXPIRY_MINUTES=30

# Tambah desimal acak kecil ke nominal supaya tiap invoice unik
# Memudahkan matching otomatis. Set ke false untuk matikan.
UNIQUE_AMOUNT=true
UNIQUE_AMOUNT_MAX=0.0099

# --- Konfigurasi Matching ---
# Toleransi selisih nominal saat matching (persen). 0.5 = ±0.5%
AMOUNT_TOLERANCE_PERCENT=0.5

# Grace period (menit) setelah expiry untuk transaksi yang telat tercatat
MATCH_GRACE_MINUTES=10

# Maksimum percobaan klaim TxId per invoice (anti-spam)
MAX_CLAIM_ATTEMPTS=10

# --- Poller ---
# Interval cek Pay Trade History + deposit on-chain (detik).
# Minimal 15 detik agar tidak kena rate limit Binance.
POLL_INTERVAL_SECONDS=20

# --- On-chain Deposit ---
# Aktifkan mode on-chain (buyer kirim via jaringan blockchain)
ONCHAIN_ENABLED=true

# Jaringan yang diterima, dipisah koma.
# Pilihan: TRC20, BEP20, ERC20, BEP2, SOL, MATIC, AVAXC, ARBITRUM, OPTIMISM
ACCEPTED_NETWORKS=TRC20,BEP20

# Deposit address Binance kamu per jaringan (format JSON).
# Cek di: Binance -> Wallet -> Fiat and Spot -> Deposit -> pilih coin & network
# Contoh USDT:
#   TRC20 -> Binance -> Deposit USDT -> pilih TRC20 -> salin address
#   BEP20 -> Binance -> Deposit USDT -> pilih BEP20 (BSC) -> salin address
DEPOSIT_ADDRESSES={"TRC20":"TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx","BEP20":"0xaabbccddeeff00112233445566778899aabbccdd"}

# --- Server ---
PORT=3000

# --- Opsional: Pin IP Binance API ---
# Hanya untuk testing lokal jika DNS diblokir. Kosongkan di VPS/produksi.
# BINANCE_RESOLVE_IP=

# --- Opsional: Ganti base URL (misal ke testnet) ---
# BINANCE_BASE_URL=https://api.binance.com

# --- Opsional: Lokasi penyimpanan data invoice ---
# DATA_DIR=./data
